# Aham AI Agent — Secrets
#
# This file holds API keys only. All other settings belong in aham.conf.
#
# Copy to .env and fill in the key for whichever provider you use.
# .env is gitignored — never commit it.
#
# Priority: shell export > .env > aham.conf > built-in defaults

# Aham LLM key 
# Set this to the API key for the provider configured in aham.conf.
# Not needed for local Ollama.
#
#API_KEY=gsk_...          # Groq
#API_KEY=sk-or-...        # OpenRouter
#API_KEY=sk-...           # OpenAI
#API_KEY=sk-ant-...       # Anthropic (via OpenAI-compat)